{
  // ── Formatting ──────────────────────────────────────────────────────────────
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.addMissingImports": "explicit",
    "source.organizeImports": "never"
  },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": { "other": "off", "comments": "off", "strings": "off" }
  },

  // ── Font & Typography ────────────────────────────────────────────────────────
  "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "editor.fontSize": 13.5,
  "editor.lineHeight": 1.7,
  "editor.fontLigatures": true,
  "editor.letterSpacing": 0.2,
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.4,

  // ── Editor Appearance ────────────────────────────────────────────────────────
  "editor.padding.top": 16,
  "editor.padding.bottom": 16,
  "editor.renderLineHighlight": "gutter",
  "editor.renderWhitespace": "selection",
  "editor.occurrencesHighlight": "singleFile",
  "editor.colorDecorators": true,
  "editor.minimap.enabled": false,
  "editor.scrollbar.verticalScrollbarSize": 6,
  "editor.scrollbar.horizontalScrollbarSize": 6,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,

  // ── Editor UX ───────────────────────────────────────────────────────────────
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.smoothScrolling": true,
  "editor.suggest.insertMode": "replace",
  "editor.inlineSuggest.enabled": true,
  "editor.tabSize": 2,

  // ── Workbench ────────────────────────────────────────────────────────────────
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.wrapTabs": false,
  "workbench.tree.indent": 14,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.activityBar.location": "default",
  "workbench.layoutControl.enabled": false,
  "workbench.tips.enabled": false,
  "breadcrumbs.enabled": true,

  // ── TypeScript ───────────────────────────────────────────────────────────────
  "typescript.tsdk": "node_modules/typescript/lib",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.suggest.autoImports": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.variableTypes.enabled": false,

  // ── ESLint ───────────────────────────────────────────────────────────────────
  "eslint.run": "onType",
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  // ── Tailwind CSS IntelliSense ─────────────────────────────────────────────
  "tailwindCSS.experimental.configFile": "src/app/globals.css",
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.cssConflict": "warning",

  // ── Explorer / File Nesting ───────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, .npmrc, .nvmrc, .node-version",
    "next.config.*": "next-env.d.ts, .next",
    "tailwind.config.*": "postcss.config.*",
    "tsconfig.json": "tsconfig.*.json, tsconfig.tsbuildinfo",
    "eslint.config.*": ".eslintignore, .prettierrc*, prettier.config.*",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx, ${capture}.stories.tsx"
  },

  // ── Search & File Watching ────────────────────────────────────────────────
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/out": true,
    "**/build": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/tsconfig.tsbuildinfo": true
  },

  // ── Git ──────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "scm.diffDecorationsGutterWidth": 2
}
